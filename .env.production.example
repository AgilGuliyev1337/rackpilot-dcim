# RackPilot DCIM — production environment
# Copy to .env.production and fill in real values. NEVER commit the real file.

# --- PostgreSQL ---
POSTGRES_USER=rackpilot
# Use a long random password, e.g. `openssl rand -base64 24`
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=rackpilot

# --- Backend / auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_a_32_byte_hex_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Number of gunicorn workers (rule of thumb: 2 * CPU cores + 1)
GUNICORN_WORKERS=4

# --- Frontend / entry ---
# Host port the app is reachable on (nginx serves SPA + proxies /api)
APP_PORT=8080

# --- AI assistant (optional) ---
# Sign up at openrouter.ai, generate an API key. Leave blank to disable the feature.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
