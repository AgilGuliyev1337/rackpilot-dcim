# RackPilot DCIM — development environment
# PostgreSQL
POSTGRES_USER=rackpilot
POSTGRES_PASSWORD=rackpilot
POSTGRES_DB=rackpilot

# Backend
DATABASE_URL=postgresql://rackpilot:rackpilot@db:5432/rackpilot
TEST_DATABASE_URL=postgresql://rackpilot:rackpilot@localhost:5432/rackpilot_test
JWT_SECRET=change-me-in-production-use-32-plus-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI assistant (optional). Sign up at openrouter.ai for a key; leave blank to disable.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
